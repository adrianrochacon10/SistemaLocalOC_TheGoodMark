# =============================================================================
# Backend Express — copiar a `.env` en esta carpeta (backend/)
# =============================================================================
#
#   cd backend
#   cp .env.example .env
#
# El frontend usa claves VITE_* definidas en el `.env` de la RAÍZ del repo;
# ver `../.env.example` sección [A].
#
# =============================================================================

# --- [B] Supabase (servidor, service role; no exponer al cliente) ---

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PORT=4000
NODE_ENV=development

# --- [C] Correo: Resend y/o SMTP ---

RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# --- [D] Scripts (node scripts/... desde backend/) ---

ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOMBRE=
VENDEDOR_NOMBRE=
VENDEDOR_EMAIL=
VENDEDOR_PASSWORD=
