# =============================================================================
# Sistema Local OC / The Good Mark — referencia de variables de entorno
# =============================================================================
#
# Cómo usar este archivo:
#   · Crea `.env` en la RAÍZ del repo con al menos la sección [A] (Vite / Tauri).
#   · Crea `backend/.env` (puedes partir de `backend/.env.example`) con [B]–[E].
#   · Si ejecutas `node scripts/*.js` desde la raíz, dotenv lee el `.env` de la
#     raíz: añade ahí las mismas claves de [B] y [D] que uses en esos scripts.
#
# Vite solo incrusta las variables VITE_* al compilar; el instalador Tauri no
# lee `.env` en tiempo de ejecución.
#
# =============================================================================

# -----------------------------------------------------------------------------
# [A] Frontend — Vite / build web / `tauri build`  (archivo: .env en la raíz)
# -----------------------------------------------------------------------------

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_BACKEND_URL=http://127.0.0.1:4000

# -----------------------------------------------------------------------------
# [B] Backend — API Express  (archivo: backend/.env; ver también raíz si usas scripts)
# -----------------------------------------------------------------------------

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PORT=4000
NODE_ENV=development

# -----------------------------------------------------------------------------
# [C] Correo — Resend y/o SMTP  (backend/src/lib/email.js)
# -----------------------------------------------------------------------------

RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# -----------------------------------------------------------------------------
# [D] Scripts — crear admin / vendedor  (scripts/ y backend/scripts/)
# -----------------------------------------------------------------------------

ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOMBRE=
VENDEDOR_NOMBRE=
VENDEDOR_EMAIL=
VENDEDOR_PASSWORD=

# -----------------------------------------------------------------------------
# [E] Opcional — Tauri desarrollo / red  (vite.config.ts)
# -----------------------------------------------------------------------------

TAURI_DEV_HOST=
